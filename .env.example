# Copie para .env.local na RAIZ do projeto (mesma pasta que package.json e next.config.mjs).
# Depois de criar/editar .env.local, pare e suba de novo: pnpm dev
#
# PRODUÇÃO (ex.: Vercel): adicione as MESMAS variáveis em Settings → Environment Variables,
# marque "Production", salve e faça Redeploy. Sem SUPABASE_SERVICE_ROLE_KEY o login admin em
# https://www.atacadodeconstrucao.com/admin/login não funciona.
#
# Formato (sem aspas obrigatórias; sem espaço antes/depois do =):
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Público (browser + servidor)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Somente servidor — obrigatório para login do painel admin e APIs que usam service role.
# Supabase Dashboard → Settings → API → service_role (nunca commitar nem expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
