# Copie para .env.local na RAIZ do projeto (mesma pasta que package.json e next.config.mjs).
# Depois de criar/editar .env.local, pare e suba de novo: pnpm dev
#
# PRODUÇÃO (ex.: Vercel): adicione as MESMAS variáveis em Settings → Environment Variables,
# marque "Production", salve e faça Redeploy.

# Público (browser + servidor)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Somente servidor — necessário para cadastro admin (INSERT em public.admins) e APIs que leem com service role.
# Supabase Dashboard → Settings → API → service_role (nunca commitar nem expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Opcional: permitir POST /api/auth/register com scope=admin (valor exato: true)
# ADMIN_REGISTRATION_OPEN=true
